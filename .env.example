# ─────────────────────────────────────────────────────────────────────────────
# Singular Agency – Odoo MCP Server – Environment Variables
# Copy this file to .env and fill in your values.
# In Hostinger Easy Deploy, set these directly in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Odoo connection (REQUIRED) ───────────────────────────────────────────────
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=your-admin@example.com
ODOO_API_KEY=your-odoo-api-key-here

# ── MCP server auth (REQUIRED for centralized deployment) ───────────────────
# This is the secret key Claude/Cowork uses to authenticate with this server.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=change-me-to-a-strong-random-secret

# ── MCP server tuning (optional, defaults shown) ────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_DEBUG=false
MCP_LOG_LEVEL=INFO

# ── Cache (optional, defaults shown) ────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000
